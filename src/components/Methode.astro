---
import { t, tObj, type Locale } from '../i18n/utils';

interface Props { locale?: Locale; variant?: 'services' | 'apps'; }
const { locale = 'fr', variant = 'services' } = Astro.props;

const s = variant === 'apps' ? 'methodeApps' : 'methode';
const badge = t(locale, `${s}.badge`);
const sectionTitle = t(locale, `${s}.title`);
const description = t(locale, `${s}.description`);
const stepsData = tObj<Array<{title: string; description: string}>>(locale, `${s}.steps`);

const iconsServices = [
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="15" y2="16"/></svg>`,
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`
];

const iconsApps = [
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`
];

const icons = variant === 'apps' ? iconsApps : iconsServices;

const steps = stepsData.map((step, i) => ({
  number: String(i + 1),
  ...step,
  icon: icons[i]
}));
---

<section id="methode" class="methode py-24 bg-white">
  <div class="container">
    <div class="section-header">
      <div class="section-badge-light inline-block px-4 py-2 bg-primary-100 text-primary-700 text-sm font-semibold rounded-full mb-4 uppercase tracking-wider">
        <span>{badge}</span>
      </div>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-neutral-900 mb-4 leading-tight">
        {sectionTitle}
      </h2>
      <p class="text-xl text-neutral-600 max-w-xl mx-auto leading-relaxed">
        {description}
      </p>
    </div>

    <div class="methode-grid grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 mt-12" data-animate data-animate-items=".methode-step" data-animate-stagger="0.15">
      {steps.map(step => (
        <div class="methode-step bg-neutral-50 rounded-3xl p-8 border border-neutral-200 text-center transition-all duration-300 hover:-translate-y-2 hover:shadow-xl hover:border-primary-300">
          <div class="step-number inline-flex items-center justify-center w-16 h-16 bg-primary-600 text-white rounded-2xl mb-5 text-2xl font-bold">
            {step.number}
          </div>
          <div class="step-icon flex items-center justify-center mb-4 text-primary-600" aria-hidden="true">
            <Fragment set:html={step.icon} />
          </div>
          <h3 class="text-xl font-bold text-neutral-900 mb-3">{step.title}</h3>
          <p class="text-neutral-600 leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import '../scripts/scroll-animate';
</script>
