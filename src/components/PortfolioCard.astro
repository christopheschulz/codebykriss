---
import { t, type Locale } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  platform: string;
  appStoreUrl?: string;
  googlePlayUrl?: string;
  websiteUrl?: string;
  tags: string[];
  locale?: Locale;
}

const { title, description, platform, appStoreUrl, googlePlayUrl, websiteUrl, tags, locale = 'fr' } = Astro.props;
---

<div class="portfolio-card bg-white rounded-3xl overflow-hidden shadow-md transition-all duration-300 border border-neutral-200 flex flex-col h-full hover:-translate-y-2 hover:shadow-2xl hover:border-purple-300">
  <div class="p-6 bg-gradient-to-br from-purple-600 to-purple-700 text-white">
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center justify-center w-12 h-12 bg-white/20 rounded-xl backdrop-blur-lg">
        {platform.includes('macOS') ? (
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
            <line x1="8" y1="21" x2="16" y2="21"/>
            <line x1="12" y1="17" x2="12" y2="21"/>
          </svg>
        ) : (
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="5" y="2" width="14" height="20" rx="2" ry="2"/>
            <line x1="12" y1="18" x2="12.01" y2="18"/>
          </svg>
        )}
      </div>
      <span class="py-2 px-3 bg-white/20 text-white text-xs font-semibold rounded-full uppercase tracking-wider backdrop-blur-lg">
        {platform}
      </span>
    </div>
    <h3 class="text-xl font-bold">{title}</h3>
  </div>

  <div class="p-6 flex-1 flex flex-col">
    <p class="text-neutral-600 leading-relaxed mb-5">{description}</p>

    <div class="flex flex-wrap gap-2 mb-6">
      {tags.map(tag => (
        <span class="inline-flex items-center py-1 px-3 bg-purple-50 text-purple-700 rounded-full text-xs font-medium">
          {tag}
        </span>
      ))}
    </div>

    <div class="mt-auto flex flex-col gap-3">
      <div class="flex flex-wrap gap-3 items-center justify-center">
      {appStoreUrl && (
        <a href={appStoreUrl} target="_blank" rel="noopener noreferrer" class="store-badge inline-block transition-opacity duration-150 hover:opacity-80">
          <svg width="140" height="42" viewBox="0 0 140 42" xmlns="http://www.w3.org/2000/svg">
            <rect width="140" height="42" rx="6" fill="#000"/>
            <g fill="#fff">
              <path d="M31.5 21.4c-.03-3.05 2.5-4.53 2.62-4.6-1.43-2.09-3.65-2.38-4.44-2.41-1.87-.2-3.68 1.12-4.63 1.12-.97 0-2.44-1.1-4.02-1.07-2.04.03-3.95 1.21-5 3.06-2.16 3.74-.55 9.24 1.52 12.27 1.03 1.48 2.24 3.13 3.83 3.07 1.55-.06 2.13-1 4-1 1.85 0 2.4 1 4.01.97 1.66-.03 2.7-1.49 3.7-2.98 1.19-1.7 1.67-3.37 1.7-3.46-.04-.01-3.25-1.24-3.29-4.97z"/>
              <path d="M28.43 12.44c.83-1.04 1.4-2.46 1.24-3.9-1.2.05-2.7.83-3.56 1.84-.77.9-1.46 2.37-1.28 3.76 1.34.1 2.72-.68 3.6-1.7z"/>
            </g>
            <g fill="#fff" font-family="Arial,Helvetica,sans-serif">
              <text x="47" y="15" font-size="8">{locale === 'fr' ? 'Télécharger dans l\'' : 'Download on the'}</text>
              <text x="47" y="29" font-size="14" font-weight="600">App Store</text>
            </g>
          </svg>
        </a>
      )}
      {googlePlayUrl && (
        <a href={googlePlayUrl} target="_blank" rel="noopener noreferrer" class="store-badge inline-block transition-opacity duration-150 hover:opacity-80">
          <svg width="155" height="42" viewBox="0 0 155 42" xmlns="http://www.w3.org/2000/svg">
            <rect width="155" height="42" rx="6" fill="#000"/>
            <g transform="translate(10, 7)">
              <path d="M0 .5l16.2 14L0 28.5V.5z" fill="#4285F4"/>
              <path d="M0 .5l16.2 14 5-4.3L0 .5z" fill="#EA4335"/>
              <path d="M0 28.5l21.2-9.7-5-4.3L0 28.5z" fill="#34A853"/>
              <path d="M21.2 18.8L28 14.5 21.2 10.2l-5 4.3 5 4.3z" fill="#FBBC04"/>
              <path d="M0 .5l21.2 9.7L28 14.5 0 .5z" fill="url(#gpGrad1)" opacity="0"/>
            </g>
            <g fill="#fff" font-family="Arial,Helvetica,sans-serif">
              <text x="44" y="15" font-size="7.5" text-transform="uppercase">{locale === 'fr' ? 'DISPONIBLE SUR' : 'GET IT ON'}</text>
              <text x="44" y="29" font-size="14" font-weight="600">Google Play</text>
            </g>
          </svg>
        </a>
      )}
      </div>
      {websiteUrl && (
        <a href={websiteUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 py-2.5 px-5 bg-primary-600 text-white no-underline rounded-lg font-semibold text-sm transition-all duration-150 hover:bg-primary-700 hover:-translate-y-0.5">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
          <span>{t(locale, 'portfolio.websiteBtn')}</span>
        </a>
      )}
    </div>
  </div>
</div>
