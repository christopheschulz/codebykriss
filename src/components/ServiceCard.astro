---
interface Props {
  title: string;
  description: string;
  features: string[];
  icon: string;
  featured?: boolean;
  badge?: string;
  showFooter?: boolean;
  priceLabel?: string;
  ctaLabel?: string;
}

const { title, description, features, icon, featured = false, badge, showFooter = true, priceLabel = '', ctaLabel = '' } = Astro.props;
---

<div class:list={[
  "service-card bg-neutral-800 rounded-3xl overflow-hidden shadow-md transition-all duration-300 border border-neutral-700 flex flex-col h-full",
  "hover:-translate-y-2 hover:shadow-2xl hover:border-primary-500/40",
  featured && "border-2 border-primary-500/40 bg-gradient-to-br from-neutral-800 to-primary-900/30"
]}>
  <div class="service-header flex items-center justify-between p-6 bg-gradient-to-br from-primary-600 to-primary-700 text-white">
    <div class="service-icon flex items-center justify-center w-12 h-12 bg-white/20 rounded-xl backdrop-blur-lg">
      <Fragment set:html={icon} />
    </div>
    {badge && (
      <span class="service-badge py-2 px-3 bg-white/20 text-white text-xs font-semibold rounded-full uppercase tracking-wider backdrop-blur-lg">
        {badge}
      </span>
    )}
  </div>

  <div class="service-content p-6 flex-1 flex flex-col">
    <h3 class="text-2xl font-bold text-white mb-3">{title}</h3>
    <p class="text-neutral-400 leading-relaxed mb-5">{description}</p>

    <ul class="service-features list-none mb-0 flex-1 flex flex-col justify-start">
      {features.map(feature => (
        <li class="flex items-center gap-3 py-2 text-neutral-300 text-sm">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-primary-400 flex-shrink-0">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          {feature}
        </li>
      ))}
    </ul>
  </div>

  {showFooter && (
    <div class="service-footer flex items-center justify-between p-6 border-t border-neutral-700 bg-neutral-800/50">
      <span class="service-price font-bold text-white text-lg">{priceLabel}</span>
      <a href="#contact" class="service-cta py-3 px-5 bg-primary-500 text-white no-underline rounded-xl font-semibold text-sm transition-all duration-150 hover:bg-primary-400 hover:-translate-y-0.5">
        {ctaLabel}
      </a>
    </div>
  )}
</div>
