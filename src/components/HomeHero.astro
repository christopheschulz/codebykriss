---
import { t, type Locale } from '../i18n/utils';

interface Props {
  locale?: Locale;
}

const { locale = 'fr' } = Astro.props;

const serviceLink = locale === 'fr' ? '/services/' : '/en/services/';
const appsLink = locale === 'fr' ? '/apps/' : '/en/apps/';
---

<section id="accueil" class="min-h-screen flex flex-col items-center justify-center bg-gradient-to-br from-primary-600 to-primary-800 text-white py-24 pb-16 relative overflow-hidden">
  <div class="hero-bg absolute inset-0 bg-[url('https://images.unsplash.com/photo-1451187580459-43490279c0fa?ixlib=rb-4.0.3')] bg-center bg-cover opacity-10 z-0"></div>

  <div class="relative z-10 text-center max-w-[1000px] w-full px-4">
    <div class="inline-flex items-center gap-2 py-2 px-4 bg-white/15 border border-white/20 rounded-full text-sm font-medium mb-6 backdrop-blur-lg">
      <span>{t(locale, 'homeHero.badge')}</span>
    </div>

    <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-6 tracking-tight">
      {t(locale, 'homeHero.title')}
      <span class="gradient-text">{t(locale, 'homeHero.titleHighlight')}</span>
    </h1>

    <p class="text-lg md:text-xl leading-relaxed mb-12 opacity-90 max-w-[700px] mx-auto">
      {t(locale, 'homeHero.description')}
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-[800px] mx-auto mb-12">
      <!-- Carte Homme de service -->
      <a href={serviceLink} class="group block bg-white/10 border border-white/20 rounded-3xl p-8 backdrop-blur-lg transition-all duration-300 hover:-translate-y-2 hover:bg-white/20 hover:shadow-2xl no-underline text-white">
        <div class="flex items-center justify-center w-16 h-16 bg-white/20 rounded-2xl mb-5 mx-auto">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
          </svg>
        </div>
        <h2 class="text-2xl font-bold mb-3">{t(locale, 'homeHero.serviceCard.title')}</h2>
        <p class="opacity-80 leading-relaxed mb-4">
          {t(locale, 'homeHero.serviceCard.description')}
        </p>
        <div class="flex items-center justify-center gap-2 text-sm font-semibold opacity-90 group-hover:opacity-100 transition-opacity">
          <span>{t(locale, 'homeHero.serviceCard.cta')}</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform duration-300 group-hover:translate-x-1">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        </div>
      </a>

      <!-- Carte Développement d'Apps -->
      <a href={appsLink} class="group block bg-white/10 border border-white/20 rounded-3xl p-8 backdrop-blur-lg transition-all duration-300 hover:-translate-y-2 hover:bg-white/20 hover:shadow-2xl no-underline text-white">
        <div class="flex items-center justify-center w-16 h-16 bg-white/20 rounded-2xl mb-5 mx-auto">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="5" y="2" width="14" height="20" rx="2" ry="2"/>
            <line x1="12" y1="18" x2="12.01" y2="18"/>
          </svg>
        </div>
        <h2 class="text-2xl font-bold mb-3">{t(locale, 'homeHero.appsCard.title')}</h2>
        <p class="opacity-80 leading-relaxed mb-4">
          {t(locale, 'homeHero.appsCard.description')}
        </p>
        <div class="flex items-center justify-center gap-2 text-sm font-semibold opacity-90 group-hover:opacity-100 transition-opacity">
          <span>{t(locale, 'homeHero.appsCard.cta')}</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform duration-300 group-hover:translate-x-1">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        </div>
      </a>
    </div>

    <!-- Section Qui suis-je résumé -->
    <div class="max-w-[700px] mx-auto bg-white/10 border border-white/20 rounded-2xl p-6 backdrop-blur-lg">
      <h3 class="text-lg font-bold mb-2">{t(locale, 'homeHero.about.title')}</h3>
      <p class="text-sm opacity-80 leading-relaxed">
        {t(locale, 'homeHero.about.description')}
      </p>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10">
    <div class="flex flex-col items-center gap-2 text-white/70 text-sm animate-bounce-slow">
      <span>{t(locale, 'homeHero.scroll')}</span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="m6 9 6 6 6-6"/>
      </svg>
    </div>
  </div>
</section>

<style>
  .gradient-text {
    background: linear-gradient(135deg, #ffffff 0%, rgba(255, 255, 255, 0.8) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
