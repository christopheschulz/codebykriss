---
import { t, type Locale } from '../i18n/utils';

interface Props {
  locale?: Locale;
}

const { locale = 'fr' } = Astro.props;

const serviceLink = locale === 'fr' ? '/services/' : '/en/services/';
const appsLink = locale === 'fr' ? '/apps/' : '/en/apps/';
---

<section id="accueil" class="min-h-screen flex flex-col items-center justify-center bg-white text-neutral-900 relative overflow-hidden">
  <div class="absolute inset-0 bg-[url('/images/hero-home.webp')] bg-center bg-cover opacity-[0.06] z-0"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-primary-100/50 via-transparent to-transparent z-0"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,_var(--tw-gradient-stops))] from-purple-100/30 via-transparent to-transparent z-0"></div>

  <div class="relative z-10 w-full max-w-[1100px] px-6 py-24">
    <div class="text-center mb-16 md:mb-20">
      <p class="text-primary-700 font-semibold text-sm tracking-widest uppercase mb-6">{t(locale, 'homeHero.badge')}</p>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold leading-[1.1] tracking-tight mb-6 text-neutral-900">
        {t(locale, 'homeHero.title')}<br/>
        <span class="bg-gradient-to-r from-primary-600 to-purple-600 bg-clip-text text-transparent">{t(locale, 'homeHero.titleHighlight')}</span>
      </h1>
      <p class="text-lg md:text-xl text-neutral-600 max-w-[600px] mx-auto leading-relaxed">
        {t(locale, 'homeHero.description')}
      </p>
    </div>

    <p class="text-center text-sm font-medium text-neutral-600 uppercase tracking-widest mb-8">
      {t(locale, 'homeHero.choosePrompt')}
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      <!-- Carte Homme de service -->
      <a href={serviceLink} class="choice-card group relative block rounded-3xl p-8 md:p-10 no-underline text-white overflow-hidden transition-all duration-500 hover:-translate-y-1">
        <div class="absolute inset-0 bg-neutral-900 border border-neutral-800 rounded-3xl transition-all duration-500 group-hover:bg-neutral-800 group-hover:border-primary-500/40 group-hover:shadow-[0_0_60px_-15px_rgba(59,130,246,0.3)]"></div>

        <div class="relative z-10">
          <div class="flex items-center justify-center w-14 h-14 bg-primary-500/20 border border-primary-400/30 rounded-2xl mb-6 transition-all duration-500 group-hover:bg-primary-500/30 group-hover:scale-110">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-primary-400">
              <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
            </svg>
          </div>

          <h2 class="text-2xl md:text-3xl font-bold mb-3 tracking-tight">{t(locale, 'homeHero.serviceCard.title')}</h2>
          <p class="text-neutral-400 leading-relaxed mb-8 text-base">
            {t(locale, 'homeHero.serviceCard.description')}
          </p>

          <div class="flex items-center gap-3 text-primary-400 font-semibold transition-all duration-300 group-hover:gap-4">
            <span class="text-base">{t(locale, 'homeHero.serviceCard.cta')}</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform duration-500 group-hover:translate-x-2">
              <path d="M5 12h14"/>
              <path d="m12 5 7 7-7 7"/>
            </svg>
          </div>
        </div>
      </a>

      <!-- Carte Développement d'Apps -->
      <a href={appsLink} class="choice-card group relative block rounded-3xl p-8 md:p-10 no-underline text-white overflow-hidden transition-all duration-500 hover:-translate-y-1">
        <div class="absolute inset-0 bg-neutral-900 border border-neutral-800 rounded-3xl transition-all duration-500 group-hover:bg-neutral-800 group-hover:border-purple-500/40 group-hover:shadow-[0_0_60px_-15px_rgba(139,92,246,0.3)]"></div>

        <div class="relative z-10">
          <div class="flex items-center justify-center w-14 h-14 bg-purple-500/20 border border-purple-400/30 rounded-2xl mb-6 transition-all duration-500 group-hover:bg-purple-500/30 group-hover:scale-110">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-purple-400">
              <rect x="5" y="2" width="14" height="20" rx="2" ry="2"/>
              <line x1="12" y1="18" x2="12.01" y2="18"/>
            </svg>
          </div>

          <h2 class="text-2xl md:text-3xl font-bold mb-3 tracking-tight">{t(locale, 'homeHero.appsCard.title')}</h2>
          <p class="text-neutral-400 leading-relaxed mb-8 text-base">
            {t(locale, 'homeHero.appsCard.description')}
          </p>

          <div class="flex items-center gap-3 text-purple-400 font-semibold transition-all duration-300 group-hover:gap-4">
            <span class="text-base">{t(locale, 'homeHero.appsCard.cta')}</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform duration-500 group-hover:translate-x-2">
              <path d="M5 12h14"/>
              <path d="m12 5 7 7-7 7"/>
            </svg>
          </div>
        </div>
      </a>
    </div>

    <div class="text-center mt-16 md:mt-20">
      <p class="text-neutral-600 text-sm max-w-[500px] mx-auto leading-relaxed">
        {t(locale, 'homeHero.about.description')}
      </p>
    </div>
  </div>
</section>
