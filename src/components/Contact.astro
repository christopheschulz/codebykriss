---
import ContactCard from './ContactCard.astro';
import { t, tObj, type Locale } from '../i18n/utils';

interface Props {
  defaultService?: string;
  locale?: Locale;
  variant?: 'services' | 'apps' | 'all';
  dark?: boolean;
}

const { defaultService = '', locale = 'fr', variant = 'all', dark = true } = Astro.props;

const s = variant === 'services' ? 'contactServices' : variant === 'apps' ? 'contactApps' : 'contact';

// Extract all translations in frontmatter
const title = t(locale, `${s}.title`);
const subtitle = t(locale, `${s}.subtitle`);
const formTitle = t(locale, `${s}.formTitle`);
const formSubtitle = t(locale, `${s}.formSubtitle`);
const calendly = t(locale, `${s}.calendly`);
const serviceLabel = t(locale, `${s}.serviceLabel`);
const nameLabel = t(locale, `${s}.nameLabel`);
const emailLabel = t(locale, `${s}.emailLabel`);
const phoneLabel = t(locale, `${s}.phoneLabel`);
const messageLabel = t(locale, `${s}.messageLabel`);
const messagePlaceholder = t(locale, `${s}.messagePlaceholder`);
const charCounter = t(locale, `${s}.charCounter`);
const submitBtn = t(locale, `${s}.submitBtn`);
const securityNote = t(locale, `${s}.securityNote`);
const validationRequired = t(locale, `${s}.validationRequired`);
const validationEmail = t(locale, `${s}.validationEmail`);
const validationPhone = t(locale, `${s}.validationPhone`);
const validationMessage = t(locale, `${s}.validationMessage`);
const successMsg = t(locale, `${s}.successMsg`);
const errorMsg = t(locale, `${s}.errorMsg`);
const sending = t(locale, `${s}.sending`);

const serviceOptions = tObj<Array<{value: string; label: string}>>(locale, `${s}.serviceOptions`);
const cardsData = tObj<Array<{title: string; description: string; badge: string}>>(locale, `${s}.cards`);

const badgeTypes: Array<'default' | 'success' | 'premium' | 'info' | 'quality'> = ['default', 'success', 'premium', 'info', 'quality'];

const icons = [
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>`,
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>`,
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>`
];

const contactCards = cardsData.map((card, i) => ({
  ...card,
  badgeType: badgeTypes[i],
  icon: icons[i],
}));
---

<section id="contact" class:list={["contact py-24 relative", dark ? "bg-neutral-900 text-white" : "bg-white text-neutral-900"]}>

  <div class="container relative z-10">
    <div class="contact-hero text-center mb-16">
      <h2 class:list={["text-3xl md:text-4xl lg:text-5xl font-extrabold mb-4", dark ? "text-white" : "text-neutral-900"]}>{title}</h2>
      <p class:list={["contact-subtitle text-lg md:text-xl max-w-[600px] mx-auto", dark ? "text-neutral-400" : "text-neutral-600"]}>
        {subtitle}
      </p>
    </div>

    <div class="contact-layout grid grid-cols-1 lg:grid-cols-[2fr_1fr] gap-8 lg:gap-12 items-start">
      <div class="contact-form-container">
        <div class:list={["contact-form-wrapper rounded-3xl p-6 md:p-8 shadow-xl border", dark ? "bg-neutral-800 border-neutral-700" : "bg-neutral-50 border-neutral-200"]}>
          <div class="form-header text-center mb-8">
            <div class:list={["form-icon inline-flex items-center justify-center w-16 h-16 rounded-2xl mb-4", dark ? "bg-primary-500/20 border border-primary-400/30 text-primary-400" : "bg-primary-600 text-white"]}>
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <h3 class:list={["text-2xl md:text-3xl font-bold mb-2", dark ? "text-white" : "text-neutral-900"]}>{formTitle}</h3>
            <p class:list={["leading-relaxed", dark ? "text-neutral-400" : "text-neutral-600"]}>
              {formSubtitle}
            </p>
            <a href="https://calendly.com/christophe-schulz/30min" target="_blank" rel="noopener noreferrer" class:list={["inline-flex items-center gap-2 mt-4 px-5 py-3 font-semibold text-sm rounded-xl transition-colors duration-200", dark ? "bg-primary-500/20 text-primary-300 border border-primary-300/30 hover:bg-primary-500/25" : "bg-primary-50 text-primary-700 hover:bg-primary-100"]}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
              {calendly}
            </a>
          </div>

          <form
            id="contact-form"
            class="professional-form flex flex-col gap-5"
            data-msg-required={validationRequired}
            data-msg-email={validationEmail}
            data-msg-phone={validationPhone}
            data-msg-message={validationMessage}
            data-msg-success={successMsg}
            data-msg-error={errorMsg}
            data-msg-sending={sending}
          >
            <div class="form-group">
              <label for="service">{serviceLabel} <span class="text-error">*</span></label>
              <select id="service" name="service" required>
                {serviceOptions.map(option => (
                  <option value={option.value} selected={option.value === defaultService} disabled={option.value === ''} hidden={option.value === ''}>{option.label}</option>
                ))}
              </select>
            </div>

            <div class="form-group">
              <label for="name">{nameLabel} <span class="text-error">*</span></label>
              <input type="text" id="name" name="name" required minlength="2" />
            </div>

            <div class="form-group">
              <label for="email">{emailLabel} <span class="text-error">*</span></label>
              <input type="email" id="email" name="email" required />
            </div>

            <div class="form-group">
              <label for="phone">{phoneLabel}</label>
              <input type="tel" id="phone" name="phone" />
            </div>

            <div class="form-group">
              <label for="message">{messageLabel} <span class="text-error">*</span></label>
              <textarea
                id="message"
                name="message"
                rows="4"
                placeholder={messagePlaceholder}
                required
                minlength="20"
              ></textarea>
              <div class="form-feedback flex justify-between items-start mt-2 min-h-[20px]">
                <span class="char-counter text-xs text-neutral-500 transition-colors duration-150">
                  <span id="message-count">0</span>/20 {charCounter}
                </span>
              </div>
            </div>

            <div class="form-actions mt-6">
              <button type="submit" class:list={["submit-btn w-full py-4 px-6 text-white border-none rounded-xl text-lg font-semibold cursor-pointer transition-all duration-300 shadow-lg hover:-translate-y-0.5 hover:shadow-xl", dark ? "bg-primary-500 hover:bg-primary-400" : "bg-primary-600 hover:bg-primary-700"]}>
                <span class="btn-content flex items-center justify-center gap-2">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="m22 2-7 20-4-9-9-4Z"/>
                    <path d="M22 2 11 13"/>
                  </svg>
                  {submitBtn}
                </span>
              </button>
              <div class="form-note flex items-center justify-center gap-2 mt-4 p-3 bg-success/10 rounded-xl text-success text-sm text-center">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/>
                  <path d="m9 12 2 2 4-4"/>
                </svg>
                {securityNote}
              </div>
            </div>
          </form>
        </div>
      </div>

      <div class="contact-info grid gap-4 order-first lg:order-last">
        {contactCards.map(card => (
          <ContactCard
            title={card.title}
            description={card.description}
            icon={card.icon}
            badge={card.badge}
            badgeType={card.badgeType}
            dark={dark}
          />
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import emailjs from '@emailjs/browser';

  emailjs.init("D9Lbpf5Qshz4fGR9F");

  const contactForm = document.getElementById('contact-form') as HTMLFormElement | null;

  if (contactForm) {
    const msgs = {
      required: contactForm.dataset.msgRequired || 'This field is required',
      email: contactForm.dataset.msgEmail || 'Please enter a valid email',
      phone: contactForm.dataset.msgPhone || 'Please enter a valid phone number',
      message: contactForm.dataset.msgMessage || 'Please enter at least 20 characters',
      success: contactForm.dataset.msgSuccess || 'Thank you!',
      error: contactForm.dataset.msgError || 'Error sending message.',
      sending: contactForm.dataset.msgSending || 'Sending...',
    };

    const messageField = document.getElementById('message') as HTMLTextAreaElement | null;
    const messageCounter = document.getElementById('message-count');

    function updateCharacterCounter() {
      if (messageField && messageCounter) {
        const currentLength = messageField.value.length;
        messageCounter.textContent = String(currentLength);
        const counterSpan = messageCounter.parentElement;
        if (counterSpan) {
          if (currentLength >= 20) {
            counterSpan.classList.add('text-success');
            counterSpan.classList.remove('text-error');
          } else {
            counterSpan.classList.add('text-error');
            counterSpan.classList.remove('text-success');
          }
        }
      }
    }

    if (messageField) {
      messageField.addEventListener('input', updateCharacterCounter);
      updateCharacterCounter();
    }

    function validateEmail(email: string): boolean {
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    }

    function validatePhone(phone: string): boolean {
      if (!phone) return true;
      return /^(?:(?:\+|00)33|0)\s*[1-9](?:[\s.-]*\d{2}){4}$/.test(phone.replace(/\s/g, ''));
    }

    function validateField(field: HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement): { isValid: boolean; errorMessage: string } {
      const formGroup = field.closest('.form-group');
      const value = field.value.trim();
      let isValid = true;
      let errorMessage = '';

      if (formGroup) {
        formGroup.classList.remove('error', 'success');
        const existingError = formGroup.querySelector('.error-message');
        if (existingError) existingError.remove();
      }

      if (field.required && !value) {
        isValid = false;
        const label = formGroup?.querySelector('label');
        const labelText = label ? label.textContent?.replace(' *', '').replace('*', '').trim() : '';
        errorMessage = msgs.required.replace('{field}', labelText || '');
      } else if (field.type === 'email' && value && !validateEmail(value)) {
        isValid = false;
        errorMessage = msgs.email;
      } else if (field.type === 'tel' && value && !validatePhone(value)) {
        isValid = false;
        errorMessage = msgs.phone;
      } else if (field.tagName === 'TEXTAREA' && field.name === 'message' && value && value.length < 20) {
        isValid = false;
        errorMessage = msgs.message.replace('{count}', String(value.length));
      }

      if (formGroup && (value || field.required)) {
        formGroup.classList.add(isValid ? 'success' : 'error');
        if (!isValid && errorMessage) {
          const errorDiv = document.createElement('div');
          errorDiv.className = 'error-message show';
          errorDiv.textContent = errorMessage;
          formGroup.appendChild(errorDiv);
        }
      }

      return { isValid, errorMessage };
    }

    const formFields = contactForm.querySelectorAll('input, textarea, select');
    formFields.forEach(field => {
      field.addEventListener('input', () => validateField(field as HTMLInputElement | HTMLSelectElement));
      field.addEventListener('change', () => validateField(field as HTMLInputElement | HTMLSelectElement));
      field.addEventListener('blur', () => validateField(field as HTMLInputElement | HTMLSelectElement));
    });

    contactForm.addEventListener('submit', async function(e) {
      e.preventDefault();

      let isFormValid = true;
      formFields.forEach(field => {
        const validation = validateField(field as HTMLInputElement | HTMLSelectElement);
        if (!validation.isValid) isFormValid = false;
      });

      if (!isFormValid) {
        const firstError = contactForm.querySelector('.form-group.error');
        if (firstError) {
          firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
          const input = firstError.querySelector('input, textarea, select') as HTMLElement;
          if (input) input.focus();
        }
        return;
      }

      const submitBtn = contactForm.querySelector('.submit-btn') as HTMLButtonElement;
      const btnContent = submitBtn.querySelector('.btn-content');
      const originalContent = btnContent?.innerHTML || '';

      submitBtn.disabled = true;
      if (btnContent) {
        btnContent.innerHTML = `
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="animate-spin">
            <path d="M21 12a9 9 0 11-6.219-8.56"/>
          </svg>
          ${msgs.sending}
        `;
      }

      try {
        await emailjs.sendForm('service_i5fh0wc', 'template_rlp6fxk', contactForm);
        showFormMessage('success', msgs.success);
        contactForm.reset();
        formFields.forEach(field => {
          field.closest('.form-group')?.classList.remove('error', 'success');
        });
        updateCharacterCounter();
      } catch (error) {
        console.error('EmailJS error:', error);
        showFormMessage('error', msgs.error);
      } finally {
        submitBtn.disabled = false;
        if (btnContent) btnContent.innerHTML = originalContent;
      }
    });

    function showFormMessage(type: 'success' | 'error', message: string) {
      let messageElement = document.querySelector('.form-message') as HTMLElement | null;
      if (!messageElement) {
        messageElement = document.createElement('div');
        messageElement.className = 'form-message';
        contactForm?.querySelector('.form-actions')?.appendChild(messageElement);
      }
      messageElement.className = `form-message mt-4 p-4 rounded-xl text-sm ${type === 'success' ? 'bg-success/10 text-success' : 'bg-error/10 text-error'}`;
      messageElement.textContent = message;
      messageElement.style.display = 'block';
      messageElement.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      setTimeout(() => { if (messageElement) messageElement.style.display = 'none'; }, 8000);
    }
  }
</script>
