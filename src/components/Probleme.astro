---
import ServiceCard from './ServiceCard.astro';
import { t, tObj, type Locale } from '../i18n/utils';

interface Props { locale?: Locale; variant?: 'services' | 'apps'; }
const { locale = 'fr', variant = 'services' } = Astro.props;

const s = variant === 'apps' ? 'problemeApps' : 'probleme';
const badge = t(locale, `${s}.badge`);
const title = t(locale, `${s}.title`);
const description = t(locale, `${s}.description`);
const cards = tObj<Array<{title: string; description: string; features: string[]}>>(locale, `${s}.cards`);

const iconsServices = [
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="18" y1="8" x2="23" y2="13"/><line x1="23" y1="8" x2="18" y2="13"/></svg>`
];

const iconsApps = [
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`
];

const icons = variant === 'apps' ? iconsApps : iconsServices;

const problemes = cards.map((card, i) => ({
  ...card,
  icon: icons[i]
}));
---

<section id="probleme" class="probleme py-24 bg-neutral-900">
  <div class="container">
    <div class="section-header">
      <div class="section-badge">
        <span>{badge}</span>
      </div>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-white mb-4 leading-tight">
        {title}
      </h2>
      <p class="section-description">
        {description}
      </p>
    </div>

    <div class="probleme-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 mt-12" data-animate data-animate-items=".service-card">
      {problemes.map(probleme => (
        <ServiceCard
          title={probleme.title}
          description={probleme.description}
          features={probleme.features}
          icon={probleme.icon}
          showFooter={false}
        />
      ))}
    </div>
  </div>
</section>

<script>
  import '../scripts/scroll-animate';
</script>
