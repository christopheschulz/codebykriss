---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const currentDate = new Date().toLocaleDateString('en-US', {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
});
---

<Layout title="Legal Notice - Code By Kriss" locale="en">
  <Header locale="en" />
  <main id="main-content" class="pt-24 pb-16 px-4">
    <div class="max-w-3xl mx-auto">
      <a href="/en/" class="inline-flex items-center gap-2 mb-6 py-2 px-4 bg-primary-600 text-white no-underline rounded-lg transition-colors duration-300 hover:bg-primary-700 text-sm font-medium">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        Back to site
      </a>

      <h1 class="text-3xl sm:text-4xl font-bold mb-4">
        <span class="bg-gradient-to-r from-primary-500 to-primary-700 bg-clip-text text-transparent">
          Legal Notice
        </span>
      </h1>

      <p class="text-sm text-neutral-500 italic mb-8">
        Last updated: {currentDate}
      </p>

      <div class="space-y-6">
        <p class="text-neutral-600">
          In accordance with the provisions of Articles 6-III and 19 of French Law No. 2004-575 of June 21, 2004, known as the Digital Economy Confidence Act (L.C.E.N.), the following information is provided to the users and visitors of this website.
        </p>

        <!-- Publisher -->
        <section class="p-6 rounded-2xl bg-neutral-50 border border-neutral-200">
          <h2 class="text-xl font-semibold mb-4 text-neutral-900">1. Website Publisher</h2>
          <div class="text-neutral-600 space-y-2">
            <p><strong>Legal name:</strong> Auto-entrepreneur Schulz Christophe Andre Erwin</p>
            <p><strong>Trade name:</strong> Code By Kriss</p>
            <p><strong>Address:</strong> 60 rue François 1er, 75008 Paris, France</p>
            <p><strong>SIRET:</strong> 989 052 840 000 18</p>
            <p><strong>Email:</strong> <a href="mailto:contact@codebykriss.fr" class="text-primary-600 hover:underline">contact@codebykriss.fr</a></p>
            <p><strong>Activity:</strong> Web and mobile application development</p>
          </div>
        </section>

        <!-- Publication Director -->
        <section class="p-6 rounded-2xl bg-neutral-50 border border-neutral-200">
          <h2 class="text-xl font-semibold mb-4 text-neutral-900">2. Publication Director</h2>
          <p class="text-neutral-600">
            <strong>Name:</strong> Christophe Schulz
          </p>
        </section>

        <!-- Host -->
        <section class="p-6 rounded-2xl bg-neutral-50 border border-neutral-200">
          <h2 class="text-xl font-semibold mb-4 text-neutral-900">3. Host</h2>
          <div class="text-neutral-600 space-y-2">
            <p><strong>Name:</strong> GitHub, Inc. (GitHub Pages)</p>
            <p><strong>Address:</strong> 88 Colin P Kelly Jr St, San Francisco, CA 94107, USA</p>
            <p><strong>Website:</strong> <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">https://github.com</a></p>
          </div>
        </section>

        <!-- Intellectual Property -->
        <section class="p-6 rounded-2xl bg-neutral-50 border border-neutral-200">
          <h2 class="text-xl font-semibold mb-4 text-neutral-900">4. Intellectual Property</h2>
          <p class="text-neutral-600">
            All content on this website (text, images, graphics, logo, icons, etc.) is the exclusive property of the publisher, with the exception of trademarks, logos, or content belonging to other partner companies or authors. Any reproduction, distribution, modification, adaptation, retransmission, or publication of these elements is strictly prohibited without the express written consent of the publisher.
          </p>
        </section>

        <!-- Personal Data -->
        <section class="p-6 rounded-2xl bg-neutral-50 border border-neutral-200">
          <h2 class="text-xl font-semibold mb-4 text-neutral-900">5. Personal Data</h2>
          <p class="text-neutral-600">
            For more information about the collection and processing of personal data, please refer to our <a href="/en/privacy-policy/" class="text-primary-600 hover:underline">Privacy Policy</a>.
          </p>
        </section>

        <!-- Cookies -->
        <section class="p-6 rounded-2xl bg-neutral-50 border border-neutral-200">
          <h2 class="text-xl font-semibold mb-4 text-neutral-900">6. Cookies</h2>
          <p class="text-neutral-600">
            This website does not use any tracking or marketing cookies. Only technical cookies necessary for the proper functioning of the site may be used.
          </p>
        </section>

        <!-- Liability -->
        <section class="p-6 rounded-2xl bg-neutral-50 border border-neutral-200">
          <h2 class="text-xl font-semibold mb-4 text-neutral-900">7. Liability</h2>
          <p class="text-neutral-600 mb-3">
            The information contained on this website is as accurate as possible and the site is periodically updated, but may nevertheless contain inaccuracies, omissions, or gaps.
          </p>
          <p class="text-neutral-600">
            If you notice any gap, error, or what appears to be a malfunction, please report it by email, describing the problem as precisely as possible.
          </p>
        </section>

        <!-- Hyperlinks -->
        <section class="p-6 rounded-2xl bg-neutral-50 border border-neutral-200">
          <h2 class="text-xl font-semibold mb-4 text-neutral-900">8. Hyperlinks</h2>
          <p class="text-neutral-600">
            Hyperlinks set up on this website directing to other resources on the Internet shall not engage the liability of Code By Kriss.
          </p>
        </section>

        <!-- Applicable Law -->
        <section class="p-6 rounded-2xl bg-neutral-50 border border-neutral-200">
          <h2 class="text-xl font-semibold mb-4 text-neutral-900">9. Applicable Law</h2>
          <p class="text-neutral-600">
            This legal notice is governed by French law. In the event of a dispute, French courts shall have sole jurisdiction.
          </p>
        </section>

        <!-- Contact -->
        <section class="p-6 rounded-2xl bg-neutral-50 border border-neutral-200">
          <h2 class="text-xl font-semibold mb-4 text-neutral-900">10. Contact</h2>
          <p class="text-neutral-600">
            For any questions regarding this legal notice, you can contact us by email at <a href="mailto:contact@codebykriss.fr" class="text-primary-600 hover:underline">contact@codebykriss.fr</a>.
          </p>
        </section>
      </div>
    </div>
  </main>
  <Footer locale="en" />
</Layout>
