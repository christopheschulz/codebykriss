---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const currentDate = new Date().toLocaleDateString('en-US', {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
});
---

<Layout title="Privacy Policy - Code By Kriss" locale="en">
  <Header locale="en" />
  <main class="pt-24 pb-16 px-4">
    <div class="max-w-3xl mx-auto">
      <a href="/en/" class="inline-flex items-center gap-2 mb-6 py-2 px-4 bg-primary-600 text-white no-underline rounded-lg transition-colors duration-300 hover:bg-primary-700 text-sm font-medium">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        Back to site
      </a>

      <h1 class="text-3xl sm:text-4xl font-bold mb-4">
        <span class="bg-gradient-to-r from-primary-500 to-primary-700 bg-clip-text text-transparent">
          Privacy Policy
        </span>
      </h1>

      <p class="text-sm text-neutral-500 italic mb-8">
        Last updated: {currentDate}
      </p>

      <div class="space-y-6">
        <!-- Introduction -->
        <section class="p-6 rounded-2xl bg-gradient-to-r from-primary-50 to-primary-100 border border-primary-200">
          <p class="text-neutral-700">
            This privacy policy describes how <strong>Code By Kriss</strong> collects, uses, and protects your personal data in accordance with the General Data Protection Regulation (GDPR).
          </p>
        </section>

        <!-- Data Controller -->
        <section class="p-6 rounded-2xl bg-neutral-50 border border-neutral-200">
          <h2 class="text-xl font-semibold mb-4 text-neutral-900">1. Data Controller</h2>
          <div class="text-neutral-600 space-y-2">
            <p><strong>Code By Kriss</strong> is the data controller for your personal data.</p>
            <p><strong>Address:</strong> 60 rue Fran&ccedil;ois 1er, 75008 Paris, France</p>
            <p><strong>Email:</strong> <a href="mailto:contact@codebykriss.fr" class="text-primary-600 hover:underline">contact@codebykriss.fr</a></p>
          </div>
        </section>

        <!-- Data Collected -->
        <section class="p-6 rounded-2xl bg-neutral-50 border border-neutral-200">
          <h2 class="text-xl font-semibold mb-4 text-neutral-900">2. Data Collected</h2>

          <div class="space-y-4 text-neutral-600">
            <div>
              <h3 class="font-medium text-neutral-800 mb-2">2.1 Navigation Data</h3>
              <p class="mb-2">When you visit our website, the following data may be collected automatically:</p>
              <ul class="list-disc list-inside space-y-1 ml-2">
                <li>IP address</li>
                <li>Browser type and version</li>
                <li>Operating system</li>
                <li>Pages visited and visit duration</li>
                <li>Date and time of connection</li>
              </ul>
            </div>

            <div>
              <h3 class="font-medium text-neutral-800 mb-2">2.2 Contact Data</h3>
              <p class="mb-2">When you use the contact form, we collect:</p>
              <ul class="list-disc list-inside space-y-1 ml-2">
                <li>First and last name</li>
                <li>Email address</li>
                <li>Company (optional)</li>
                <li>Phone number (optional)</li>
                <li>Message and voluntarily provided information</li>
              </ul>
            </div>

            <div>
              <h3 class="font-medium text-neutral-800 mb-2">2.3 Data We Do NOT Collect</h3>
              <p class="mb-2">We <strong>never</strong> collect:</p>
              <ul class="list-disc list-inside space-y-1 ml-2">
                <li>Banking or payment information</li>
                <li>Precise geographic location</li>
                <li>Sensitive data (political opinions, religious beliefs, etc.)</li>
              </ul>
            </div>
          </div>
        </section>

        <!-- Processing Purposes -->
        <section class="p-6 rounded-2xl bg-neutral-50 border border-neutral-200">
          <h2 class="text-xl font-semibold mb-4 text-neutral-900">3. Processing Purposes</h2>
          <p class="text-neutral-600 mb-3">Your data is processed for the following purposes:</p>
          <ul class="list-disc list-inside space-y-2 text-neutral-600 ml-2">
            <li><strong>Site operation:</strong> Ensuring the proper functioning and security of the website</li>
            <li><strong>Communication:</strong> Responding to your contact requests and providing quotes</li>
            <li><strong>Improvement:</strong> Analyzing site usage to improve it</li>
          </ul>
        </section>

        <!-- Legal Basis -->
        <section class="p-6 rounded-2xl bg-neutral-50 border border-neutral-200">
          <h2 class="text-xl font-semibold mb-4 text-neutral-900">4. Legal Basis</h2>
          <p class="text-neutral-600 mb-3">The processing of your data is based on:</p>
          <ul class="list-disc list-inside space-y-2 text-neutral-600 ml-2">
            <li><strong>Consent:</strong> For submitting the contact form</li>
            <li><strong>Legitimate interest:</strong> For site operation and audience analysis</li>
            <li><strong>Contract execution:</strong> For providing our development services</li>
          </ul>
        </section>

        <!-- Data Retention -->
        <section class="p-6 rounded-2xl bg-neutral-50 border border-neutral-200">
          <h2 class="text-xl font-semibold mb-4 text-neutral-900">5. Data Retention</h2>
          <ul class="list-disc list-inside space-y-2 text-neutral-600 ml-2">
            <li><strong>Navigation data:</strong> 13 months maximum</li>
            <li><strong>Contact data:</strong> 3 years after the last contact</li>
            <li><strong>Contractual data:</strong> Applicable legal retention period</li>
          </ul>
        </section>

        <!-- Data Recipients -->
        <section class="p-6 rounded-2xl bg-neutral-50 border border-neutral-200">
          <h2 class="text-xl font-semibold mb-4 text-neutral-900">6. Data Recipients</h2>
          <p class="text-neutral-600 mb-3">Your data may be shared with:</p>
          <ul class="list-disc list-inside space-y-2 text-neutral-600 ml-2">
            <li><strong>GitHub Pages:</strong> Our hosting provider (for site operation)</li>
            <li><strong>EmailJS:</strong> Email sending service (for the contact form)</li>
          </ul>
          <p class="text-neutral-600 mt-3">
            <strong>No data is sold or transferred to third parties for commercial purposes.</strong>
          </p>
        </section>

        <!-- Data Security -->
        <section class="p-6 rounded-2xl bg-neutral-50 border border-neutral-200">
          <h2 class="text-xl font-semibold mb-4 text-neutral-900">7. Data Security</h2>
          <p class="text-neutral-600 mb-3">We implement appropriate technical and organizational measures to protect your data:</p>
          <ul class="list-disc list-inside space-y-1 text-neutral-600 ml-2">
            <li>Encrypted communications (HTTPS)</li>
            <li>Limited access to data</li>
            <li>Regular system updates</li>
          </ul>
        </section>

        <!-- Your Rights -->
        <section class="p-6 rounded-2xl bg-neutral-50 border border-neutral-200">
          <h2 class="text-xl font-semibold mb-4 text-neutral-900">8. Your Rights (GDPR)</h2>
          <p class="text-neutral-600 mb-3">Under the GDPR, you have the following rights:</p>

          <div class="space-y-3 text-neutral-600">
            <div>
              <h3 class="font-medium text-neutral-800">8.1 Right of Access</h3>
              <p>You may request access to the personal data we hold about you.</p>
            </div>
            <div>
              <h3 class="font-medium text-neutral-800">8.2 Right to Rectification</h3>
              <p>You may request the correction of inaccurate or incomplete data.</p>
            </div>
            <div>
              <h3 class="font-medium text-neutral-800">8.3 Right to Erasure</h3>
              <p>You may request the deletion of your data in certain circumstances.</p>
            </div>
            <div>
              <h3 class="font-medium text-neutral-800">8.4 Right to Restriction</h3>
              <p>You may request the restriction of processing of your data.</p>
            </div>
            <div>
              <h3 class="font-medium text-neutral-800">8.5 Right to Data Portability</h3>
              <p>You may request to receive your data in a structured, commonly used format.</p>
            </div>
            <div>
              <h3 class="font-medium text-neutral-800">8.6 Right to Object</h3>
              <p>You may object to the processing of your data on legitimate grounds.</p>
            </div>
          </div>

          <p class="text-neutral-600 mt-4">
            To exercise these rights, contact us at <a href="mailto:contact@codebykriss.fr" class="text-primary-600 hover:underline">contact@codebykriss.fr</a>, specifying your request.
          </p>
        </section>

        <!-- Cookies -->
        <section class="p-6 rounded-2xl bg-neutral-50 border border-neutral-200">
          <h2 class="text-xl font-semibold mb-4 text-neutral-900">9. Cookies</h2>
          <p class="text-neutral-600 mb-3">
            Our website does not use any tracking or marketing cookies. Only technical cookies necessary for the proper functioning of the site may be used.
          </p>
          <p class="text-neutral-600">
            Should we use cookies in the future, we will inform you and obtain your consent where required.
          </p>
        </section>

        <!-- Modifications -->
        <section class="p-6 rounded-2xl bg-neutral-50 border border-neutral-200">
          <h2 class="text-xl font-semibold mb-4 text-neutral-900">10. Modifications</h2>
          <p class="text-neutral-600">
            This privacy policy may be updated to reflect changes in our practices or regulations. Significant changes will be communicated on the website. The last update date is indicated at the top of this document.
          </p>
        </section>

        <!-- Complaints -->
        <section class="p-6 rounded-2xl bg-neutral-50 border border-neutral-200">
          <h2 class="text-xl font-semibold mb-4 text-neutral-900">11. Complaints</h2>
          <p class="text-neutral-600 mb-3">
            If you believe your rights are not being respected, you may file a complaint with the French Data Protection Authority (CNIL):
          </p>
          <ul class="list-none space-y-1 text-neutral-600">
            <li><strong>Website:</strong> <a href="https://www.cnil.fr" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">www.cnil.fr</a></li>
            <li><strong>Address:</strong> 3 Place de Fontenoy - TSA 80715 - 75334 PARIS CEDEX 07</li>
            <li><strong>Phone:</strong> 01 53 73 22 22</li>
          </ul>
        </section>

        <!-- Contact -->
        <section class="p-6 rounded-2xl bg-neutral-50 border border-neutral-200">
          <h2 class="text-xl font-semibold mb-4 text-neutral-900">12. Contact</h2>
          <p class="text-neutral-600">
            For any questions regarding this privacy policy or your personal data, contact us at <a href="mailto:contact@codebykriss.fr" class="text-primary-600 hover:underline">contact@codebykriss.fr</a>.
          </p>
        </section>
      </div>
    </div>
  </main>
  <Footer locale="en" />
</Layout>
