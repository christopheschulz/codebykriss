---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { t, type Locale } from '../../i18n/utils';
import Probleme from '../../components/Probleme.astro';
import Methode from '../../components/Methode.astro';
import Formules from '../../components/Formules.astro';
import Parcours from '../../components/Parcours.astro';
import Contact from '../../components/Contact.astro';
import Footer from '../../components/Footer.astro';

const locale: Locale = 'en';
---

<Layout title={t(locale, 'meta.titleServices')} locale={locale}>
  <Header locale={locale} />
  <main id="main-content">
    <section id="accueil" class="min-h-[85vh] flex items-center justify-center bg-white text-neutral-900 relative overflow-hidden">
      <div class="absolute inset-0 bg-[url('/images/hero-services.webp')] bg-center bg-cover opacity-[0.12] z-0"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,_var(--tw-gradient-stops))] from-primary-100/50 via-transparent to-transparent z-0"></div>

      <div class="relative z-10 text-center max-w-[900px] w-full px-6 py-24">
        <div class="inline-flex items-center gap-2 py-2 px-5 bg-primary-100 border border-primary-200 rounded-full text-sm font-semibold mb-8 text-primary-700 tracking-wide">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
          </svg>
          <span>{t(locale, 'servicesHero.badge')}</span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-7xl font-extrabold leading-[1.1] mb-6 tracking-tight">
          {t(locale, 'servicesHero.title')}<br/>
          <span class="bg-gradient-to-r from-primary-600 to-primary-500 bg-clip-text text-transparent">{t(locale, 'servicesHero.titleHighlight')}</span>
        </h1>

        <p class="text-lg md:text-xl leading-relaxed mb-10 text-neutral-500 max-w-[650px] mx-auto">
          {t(locale, 'servicesHero.description')}
        </p>

        <div class="flex flex-col md:flex-row gap-4 justify-center items-center">
          <a href="#contact" class="inline-flex items-center gap-2 py-4 px-8 bg-primary-600 text-white no-underline rounded-xl font-semibold text-base transition-all duration-300 hover:bg-primary-700 hover:-translate-y-0.5 hover:shadow-xl">
            <span>{t(locale, 'servicesHero.ctaDiag')}</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14"/>
              <path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
          <a href="#methode" class="inline-flex items-center gap-2 py-4 px-8 bg-neutral-100 border border-neutral-200 text-neutral-700 no-underline rounded-xl font-semibold text-base transition-all duration-300 hover:bg-neutral-200">
            <span>{t(locale, 'servicesHero.ctaMethod')}</span>
          </a>
          <a href="https://calendly.com/christophe-schulz/30min" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 py-4 px-8 bg-neutral-100 border border-neutral-200 text-neutral-700 no-underline rounded-xl font-semibold text-base transition-all duration-300 hover:bg-neutral-200">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            <span>{t(locale, 'servicesHero.ctaRdv')}</span>
          </a>
        </div>
      </div>
    </section>
    <Probleme locale={locale} />
    <Methode locale={locale} />
    <Formules locale={locale} />
    <Parcours locale={locale} />
    <Contact defaultService="service-numerique" locale={locale} variant="services" />
  </main>
  <Footer locale={locale} />
</Layout>
