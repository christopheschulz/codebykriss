---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import AppsHero from '../../components/AppsHero.astro';
import AppsServices from '../../components/AppsServices.astro';
import Portfolio from '../../components/Portfolio.astro';
import Parcours from '../../components/Parcours.astro';
import Contact from '../../components/Contact.astro';
import Footer from '../../components/Footer.astro';
import { t, type Locale } from '../../i18n/utils';

const locale: Locale = 'en';
---

<Layout title={t(locale, 'meta.titleApps')} locale={locale}>
  <Header locale={locale} />
  <main>
    <AppsHero locale={locale} />
    <AppsServices locale={locale} />
    <Portfolio locale={locale} />
    <Parcours locale={locale} variant="apps" dark={true} />
    <Contact defaultService="app-mobile" locale={locale} variant="apps" dark={false} />
  </main>
  <Footer locale={locale} />
</Layout>
